{% extends 'base.html.twig' %}

{% block title %}Programmer un match - UniGames{% endblock %}

{% block breadcrumb %}Compétition / Matchs / <span>Programmer un match</span>{% endblock %}

{% block body %}
<div class="fmain max-w-4xl mx-auto">
    {{ form_start(form) }}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="fcard">
                <div class="fstitle">Planification <span class="twig-hint">MatchGameType</span></div>
                
                <div class="fg mb-6">
                    <label class="fgl">Date et heure du match *</label>
                    {{ form_widget(form.date_match, {'attr': {'class': 'fgi foc'}}) }}
                    {{ form_errors(form.date_match) }}
                </div>

                <div class="fg mb-6">
                    <label class="fgl">Lieu de la rencontre *</label>
                    {{ form_widget(form.lieu, {'attr': {'class': 'fgi', 'placeholder': 'Ex: Stade de l\'Université'}}) }}
                    {{ form_errors(form.lieu) }}
                </div>

                <div class="fg">
                    <label class="fgl">Phase de la compétition *</label>
                    {{ form_widget(form.phase, {'attr': {'class': 'fgi', 'placeholder': 'Ex: Phase de poules'}}) }}
                    {{ form_errors(form.phase) }}
                </div>
            </div>

            <div class="space-y-6" x-data="{
                discipline: '{{ form.discipline.vars.value ?? '' }}',
                init() {
                    this.filterEquipes();
                },
                filterEquipes() {
                    let selectA = $refs.equipeASelect;
                    let selectB = $refs.equipeBSelect;
                    
                    [selectA, selectB].forEach(select => {
                        let options = select.querySelectorAll('option');
                        options.forEach(opt => {
                            if (!opt.value) return;
                            if (this.discipline === '' || opt.dataset.discipline === this.discipline) {
                                opt.style.display = '';
                                opt.disabled = false;
                            } else {
                                opt.style.display = 'none';
                                opt.disabled = true;
                                if (opt.selected) opt.selected = false;
                            }
                        });
                    });
                }
            }">
                <div class="fcard">
                    <div class="fstitle">Configuration</div>
                    <div class="fg mb-4">
                        <label class="fgl">Édition *</label>
                        {{ form_widget(form.edition, {'attr': {'class': 'fgi'}}) }}
                    </div>
                    <div class="fg">
                        <label class="fgl">Discipline *</label>
                        {{ form_widget(form.discipline, {'attr': {'class': 'fgi', 'x-model': 'discipline', '@change': 'filterEquipes'}}) }}
                    </div>
                </div>

                <div class="fcard">
                    <div class="fstitle">Adversaires</div>
                    <div class="fg mb-4">
                        <label class="fgl">Équipe A *</label>
                        {{ form_widget(form.equipeA, {'attr': {'class': 'fgi', 'x-ref': 'equipeASelect'}}) }}
                    </div>
                    <div class="fg">
                        <label class="fgl">Équipe B *</label>
                        {{ form_widget(form.equipeB, {'attr': {'class': 'fgi', 'x-ref': 'equipeBSelect'}}) }}
                    </div>
                </div>
            </div>
        </div>

        <div class="factions mt-6">
            <a href="{{ path('app_match_index') }}" class="fac flex items-center gap-2">
                <i class="ti ti-arrow-left"></i> Annuler
            </a>
            <button type="submit" class="fap flex items-center gap-2">
                Programmer la rencontre <i class="ti ti-arrow-right"></i>
            </button>
        </div>
    {{ form_end(form) }}
</div>

<style>
    .fcard { background:#fff; border-radius:7px; border:0.5px solid #DDE3ED; padding:24px; margin-bottom:0; }
    .fstitle { font-size:10px; font-weight:700; color:#8A96A8; text-transform:uppercase; letter-spacing:.07em; margin-bottom:20px; padding-bottom:8px; border-bottom:0.5px solid #DDE3ED; display:flex; justify-content:space-between; }
    .fg { display:flex; flex-direction:column; gap:6px; }
    .fgl { font-size:11px; font-weight:600; color:#374151; }
    .fgi { height:40px; border:1.5px solid #DDE3ED; border-radius:6px; padding:0 12px; font-size:13px; background:#fff; color:#0D1F3C; width:100%; transition:all 0.2s; outline:none; }
    .fgi:focus { border-color:#005BAA; box-shadow:0 0 0 3px rgba(0,91,170,0.1); }
    .factions { display:flex; align-items:center; justify-content:flex-end; gap:12px; }
    .fac { font-size:12px; padding:8px 16px; border-radius:6px; border:1px solid #DDE3ED; color:#8A96A8; background:transparent; cursor:pointer; font-weight:600; text-decoration:none; }
    .fap { font-size:12px; padding:8px 20px; border-radius:6px; background:#005BAA; color:#fff; border:none; cursor:pointer; font-weight:700; }
</style>
{% endblock %}
