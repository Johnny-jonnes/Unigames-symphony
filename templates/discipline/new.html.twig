{% extends 'base.html.twig' %}

{% block title %}Nouvelle Discipline - UniGames{% endblock %}

{% block breadcrumb %}Gestion / Disciplines / <span>Nouvelle discipline</span>{% endblock %}

{% block body %}
<div class="fmain max-w-2xl mx-auto">
    {{ form_start(form) }}
        <div class="fcard">
            <div class="fstitle">Configuration de la discipline <span class="twig-hint">DisciplineType</span></div>
            
            <div class="fg mb-6">
                <label class="fgl">Nom de la discipline *</label>
                {{ form_widget(form.nom, {'attr': {'class': 'fgi foc', 'placeholder': 'Ex: Football'}}) }}
                {{ form_errors(form.nom) }}
            </div>

            <div class="fg">
                <label class="fgl">Nombre de joueurs par équipe *</label>
                {{ form_widget(form.nombre_joueurs_par_equipe, {'attr': {'class': 'fgi'}}) }}
                {{ form_errors(form.nombre_joueurs_par_equipe) }}
            </div>
        </div>

        <div class="factions">
            <a href="{{ path('app_discipline_index') }}" class="fac flex items-center gap-2">
                <i class="ti ti-arrow-left"></i> Annuler
            </a>
            <button type="submit" class="fap flex items-center gap-2">
                Enregistrer la discipline <i class="ti ti-arrow-right"></i>
            </button>
        </div>
    {{ form_end(form) }}
</div>

<style>
    .fcard { background:#fff; border-radius:7px; border:0.5px solid #DDE3ED; padding:24px; margin-bottom:16px; }
    .fstitle { font-size:10px; font-weight:700; color:#8A96A8; text-transform:uppercase; letter-spacing:.07em; margin-bottom:20px; padding-bottom:8px; border-bottom:0.5px solid #DDE3ED; display:flex; justify-content:space-between; }
    .fg { display:flex; flex-direction:column; gap:6px; }
    .fgl { font-size:11px; font-weight:600; color:#374151; }
    .fgi { height:40px; border:1.5px solid #DDE3ED; border-radius:6px; padding:0 12px; font-size:13px; background:#fff; color:#0D1F3C; width:100%; transition:all 0.2s; outline:none; }
    .fgi:focus { border-color:#005BAA; box-shadow:0 0 0 3px rgba(0,91,170,0.1); }
    .factions { display:flex; align-items:center; justify-content:flex-end; gap:12px; }
    .fac { font-size:12px; padding:8px 16px; border-radius:6px; border:1px solid #DDE3ED; color:#8A96A8; background:transparent; cursor:pointer; font-weight:600; text-decoration:none; }
    .fap { font-size:12px; padding:8px 20px; border-radius:6px; background:#005BAA; color:#fff; border:none; cursor:pointer; font-weight:700; }
</style>
{% endblock %}
